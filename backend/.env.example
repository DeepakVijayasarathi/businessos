# ═══════════════════════════════════════════════════════
#  BusinessOS AI — Environment Configuration
# ═══════════════════════════════════════════════════════
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_NAME=BusinessOS AI
APP_URL=http://localhost:3000
API_URL=http://localhost:5000
# Optional: comma-separated list of allowed CORS origins. Overrides the
# APP_URL-based default — set this when the app is reached via a server
# IP/domain rather than "localhost" (e.g. production deployments).
# CORS_ORIGINS=http://your-domain.com,http://1.2.3.4:3000

# ── Database ─────────────────────────────────────────────
# Remote PostgreSQL (replace with your own)
DATABASE_URL=postgresql://user:password@host:5432/businessos_db

# ── JWT ──────────────────────────────────────────────────
# Minimum 32 characters each — generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (optional — in-memory fallback used if empty) ──
REDIS_URL=redis://localhost:6379

# ── File Storage ─────────────────────────────────────────
STORAGE_TYPE=local       # 'local' | 's3'
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=50         # MB

# S3 / Compatible storage (Cloudflare R2, MinIO, etc.)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=             # leave empty for AWS; set for R2/MinIO

# ══════════════════════════════════════════════════════════
#  AI CONFIGURATION
#  Set AI_PROVIDER to 'claude' to use Anthropic Claude, or
#  'openai' to use ChatGPT/OpenAI. Add the matching API key.
# ══════════════════════════════════════════════════════════

# Active provider: 'claude' | 'openai'
AI_PROVIDER=claude

# ── Claude (Anthropic) ──────────────────────────────────
# Get key: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Model options:
#   claude-sonnet-4-6         ← best balance (default)
#   claude-haiku-4-5-20251001 ← fastest & cheapest
#   claude-opus-4-8           ← most capable
AI_CLAUDE_MODEL=claude-sonnet-4-6

# ── ChatGPT (OpenAI) ────────────────────────────────────
# Get key: https://platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# Model options:
#   gpt-4o       ← best balance (default)
#   gpt-4o-mini  ← fastest & cheapest
#   gpt-4-turbo  ← most capable
AI_OPENAI_MODEL=gpt-4o

# Max tokens per AI response (default 1024)
AI_MAX_TOKENS=1024

# ── Email (SMTP) ─────────────────────────────────────────
# Gmail: enable 2FA then create an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ── WhatsApp (Meta Cloud API) ────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=businessos-verify-2026

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Encryption ───────────────────────────────────────────
# Must be exactly 32 characters
ENCRYPTION_KEY=32-char-encryption-key-here-----

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW=15     # minutes
RATE_LIMIT_MAX=100       # requests per window

# ── Super Admin (first login) ────────────────────────────
SUPER_ADMIN_EMAIL=admin@businessos.ai
SUPER_ADMIN_PASSWORD=Admin@1234
